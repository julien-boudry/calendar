{
    "name": "condorcet-php/php-calendars",
    "description": "Pure PHP implementation of the Arabic (Hijri), French, Gregorian, Jewish, Julian and Persian (Jalali) calendars. Also provides a drop-in replacement for the PHP ext/calendar extension.",
    "type": "library",
    "keywords": [
        "calendar", "ext-calendar", "julian day", "julian day number",
        "arabic", "hijri", "persian", "jalali", "shamsi",
        "gregorian", "julian", "jewish", "hebrew", "french"
    ],
    "homepage": "https://github.com/condorcet-php/php-calendars",
    "license": "GPL-3.0-or-later",
    "authors": [{
            "name": "Greg Roach",
            "email": "greg@subaqua.co.uk",
            "role": "Original Developer"
    }, {
            "name": "Julien Boudry",
            "email": "julien@condorcet.io",
            "role": "Developer"
    }],
    "support": {
            "issues": "https://github.com/condorcet-php/php-calendars/issues"
    },
    "require": {
        "php": ">=8.5",
        "php-64bit": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3",
        "pestphp/pest": "^4.4",
        "phpbench/phpbench": "^1.6"
    },
    "provide": {
        "ext-calendar": "1"
    },
    "autoload": {
        "files": [
            "src/shims.php"
        ],
        "psr-4": {
            "CondorcetPHP\\PhpCalendars\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "CondorcetPHP\\PhpCalendars\\Benchmarks\\": "benchmarks/"
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "php-cs-fixer fix",
        "phpstan": "phpstan analyse --no-interaction",
        "rector": "rector process --dry-run",
        "bench": "phpbench run --report=aggregate"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
